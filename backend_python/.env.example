# ============================================================
# Jean-Heude — Configuration (mode hybride)
# Backend sur l'hôte | Services dans Docker
# ============================================================
# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS committer .env dans git.

# === SERVICES DOCKER (ports exposés sur localhost) ===
URL_QDRANT=localhost
STT_SERVER_URL=http://localhost:8001/transcribe
TTS_SERVER_URL=http://localhost:8002/generate
FRONTEND_URL=http://localhost:3004

# === NEO4J ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# === OLLAMA (LLM local — peut être sur une autre machine) ===
URL_SERVER_OLLAMA=http://<IP_SERVEUR_OLLAMA>:11434

# === AUTH JWT ===
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
JEAN_HEUDE_SECRET=

# === BOTS ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# === OUTILS EXTERNES ===
BRAVE_API_KEY=
WORLD_MONITOR_URL=
